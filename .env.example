# ── Headless Oracle ──────────────────────────────────────────────────────────
# Get your API key at https://headlessoracle.com
# Without a key the agent uses /v5/demo (public, rate-limited, receipt_mode=demo)
ORACLE_API_KEY=ok_live_your_key_here

# Optional: pin the public key to skip the /v5/keys fetch on every verification.
# Strongly recommended for production. Get the current key at:
#   curl https://headlessoracle.com/v5/keys | jq -r '.public_key'
ORACLE_PUBLIC_KEY=03dc27993a2c90856cdeb45e228ac065f18f69f0933c917b2336c1e75712f178

# ── LLM (optional) ───────────────────────────────────────────────────────────
# Without this the reasoning node runs in passthrough mode.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Agent config ─────────────────────────────────────────────────────────────
# MIC code for the target exchange. Supported: XNYS XNAS XLON XJPX XPAR XHKG XSES
DEFAULT_MIC=XNYS
